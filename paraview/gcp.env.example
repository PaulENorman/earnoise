# Copy this file to paraview/gcp.env and fill in your local project settings.
# This tracked template intentionally contains no account-specific values.

# Example: your-gcp-project-id
GCP_PROJECT=your-gcp-project-id

PARAVIEW_GCP_ZONE=us-central1-a
PARAVIEW_VM_NAME=paraview-viewer
PARAVIEW_VM_MACHINE_TYPE=n2-highmem-4
PARAVIEW_VM_DISK_SIZE_GB=10
PARAVIEW_VM_DISK_TYPE=pd-balanced
PARAVIEW_VM_IMAGE_PROJECT=ubuntu-os-cloud
PARAVIEW_VM_IMAGE_FAMILY=ubuntu-minimal-2404-lts-amd64
PARAVIEW_VERSION=6.1.1
ARTIFACT_REGISTRY_LOCATION=us-central1
ARTIFACT_REGISTRY_REPOSITORY=your-docker-repo
PARAVIEW_IMAGE_NAME=paraview-pvserver
PARAVIEW_IMAGE_TAG=${ARTIFACT_REGISTRY_LOCATION}-docker.pkg.dev/${GCP_PROJECT}/${ARTIFACT_REGISTRY_REPOSITORY}/${PARAVIEW_IMAGE_NAME}:v${PARAVIEW_VERSION}
PARAVIEW_IMAGE_PUBLISH_BACKEND=cloud-build
PARAVIEW_BUILD_PLATFORM=linux/amd64
PARAVIEW_PORT=11111
PARAVIEW_CASE_ROOT=gs://your-results-bucket
# Empty syncs the full PARAVIEW_CASE_ROOT. Set to a subpath for a narrower sync.
BUCKET_CASE_PATH=
LOCAL_PARAVIEW_APP=/Applications/ParaView-6.1.1.app
