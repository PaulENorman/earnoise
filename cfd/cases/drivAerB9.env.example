# Case-specific settings for the reduced steady-state DrivAer B9 workflow.

CASE_NAME=drivAerB9Steady
RESULTS_PREFIX=drivAer/b9-steady
CONTAINER_RUN_SCRIPT=runDrivAerB9SteadyInContainer.sh

# Prefer storing the public DaRUS download zip in Cloud Storage once and reusing it.
# Example:
# CASE_INPUT_GCS_URI=gs://your-case-input-bucket/doi-10.18419-darus-3737.zip
CASE_INPUT_GCS_URI=

# Optional fallback for a one-off local upload instead of bucket-backed reuse.
CASE_INPUT_FILE=/absolute/path/to/doi-10.18419-darus-3737.zip

# Coarser startup settings for a small-to-medium VM.
DRIVAER_BLOCK_CELLS="24 20 12"
DRIVAER_SURFACE_LEVEL=5
DRIVAER_ADD_LAYERS=false
DRIVAER_STEADY_END_TIME=1000
DRIVAER_WRITE_INTERVAL=250
