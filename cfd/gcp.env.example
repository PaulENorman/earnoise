# Copy this file to cfd/gcp.env and fill in your local project settings.
# This tracked template intentionally contains no account-specific values.

# Example: your-gcp-project-id
GCP_PROJECT=your-gcp-project-id
GCP_ZONE=us-central1-f
GCP_VM_NAME=cfd-compute
GCP_VM_MACHINE_TYPE=e2-medium
GCP_VM_DISK_SIZE_GB=30
GCP_VM_DISK_TYPE=pd-balanced
GCP_VM_IMAGE_PROJECT=debian-cloud
GCP_VM_IMAGE_FAMILY=debian-12
GCS_BUCKET_URI=gs://your-results-bucket

DOCKER_IMAGE_TAG=earnoise-openfoam:v2506
CASE_CPUS=2

# local = run on VM, copy artifacts back locally, then upload with local gcloud
# vm    = run on VM and upload from the VM itself
UPLOAD_MODE=vm

# Set to 1 to stop the VM after a successful run and avoid idle compute costs.
STOP_VM_AFTER_RUN=1
