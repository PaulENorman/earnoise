# Copy this file to cfd/gcp.env and fill in your local project settings.
# This tracked template intentionally contains no account-specific values.

# Example: your-gcp-project-id
GCP_PROJECT=your-gcp-project-id
GCP_ZONE=us-central1-f
GCP_VM_NAME=cfd-compute
GCP_VM_MACHINE_TYPE=e2-medium
GCP_VM_DISK_SIZE_GB=30
GCP_VM_DISK_TYPE=pd-balanced
GCP_VM_IMAGE_PROJECT=debian-cloud
GCP_VM_IMAGE_FAMILY=debian-12
GCS_BUCKET_URI=gs://your-results-bucket

ARTIFACT_REGISTRY_LOCATION=us-central1
ARTIFACT_REGISTRY_REPOSITORY=your-docker-repo
DOCKER_IMAGE_NAME=cfd-openfoam
OPENFOAM_VERSION=2306
DOCKER_IMAGE_TAG=${ARTIFACT_REGISTRY_LOCATION}-docker.pkg.dev/${GCP_PROJECT}/${ARTIFACT_REGISTRY_REPOSITORY}/${DOCKER_IMAGE_NAME}:v${OPENFOAM_VERSION}
IMAGE_PUBLISH_BACKEND=cloud-build
DOCKER_BUILD_PLATFORM=linux/amd64
CASE_CPUS=8

# local = run on VM, copy artifacts back locally, then upload with local gcloud
# vm    = run on VM and upload from the VM itself
UPLOAD_MODE=vm

# Set to 1 to stop the VM after the remote runner exits and avoid idle compute costs.
# The stop now happens on the VM side so detached runs can finish safely.
STOP_VM_AFTER_RUN=1

# Default to detached submit so the VM behaves more like a simple queue worker.
DETACH_AFTER_SUBMIT=1
